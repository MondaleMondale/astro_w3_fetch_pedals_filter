---
const { jsonObj } = Astro.props;
---

<article data-type={jsonObj.type} data-shortname={jsonObj.shortname} class="pedal_card">
  <div id="img_container">
    <img src={"/bosspedaler/" + jsonObj.webp} alt="guitar effect" />
    <!-- <img src={"https://mjjuobnpjkqieqqajriw.supabase.co/storage/v1/object/public/pedal_imgs/" + jsonObj.image} alt="guitar effect" /> -->
  </div>

  <a id="text_container" href={"/pedals/" + jsonObj.slug}>
    <h3>{jsonObj.shortname}</h3>
  </a>
</article>
<style>
  article {
    display: flex;
    flex-direction: column;
    align-items: center;
    background-color: black
    border-radius: 4px;
    padding-top: 10px;
    height: 400px;
    position:relative;
    /* aspect-ratio: 1/2; */
    
  }
#img_container:after {
    position: absolute;
    content:"";
    height:100%;
    width:100%;
    top:0;
    left:0;
    background: radial-gradient(ellipse at 35% 30%,rgba(5, 0, 0, 0) 10%, rgba(0, 0, 0, 1) 70%);
}


#img_container:hover:after {
    background: radial-gradient(ellipse,rgba(5, 0, 0, 0) 10%, rgba(0, 0, 0, 1) 100%);
}
  #img_container {
    position: relative;
    display: flex;
    justify-content: center;
    align-items: center;

    background-color: black;
     width: 90%;
     height: 80%; 
    border-radius: 4px;
    margin-bottom: 10px;
    
    /* filter: invert(); */
  }
  #text_container {
    /* margin-top: 4px; */
    background-color: black
    width: 90%;
    border-radius: 4px;
    transition: 0.5s all;
    text-decoration: none;
    /* color: rgb(227, 174, 105); */
    color: slateblue;
  }
  #text_container:hover {
    filter: drop-shadow(0 0 1rem white);
     /* background-color: rgb(225, 224, 224);  */
  }
  h3 {
    margin-left: 12px;
  }
  .hide {
    display: none;
  }
</style>
